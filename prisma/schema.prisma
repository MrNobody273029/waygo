generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  HOST
  ADMIN
}

enum BookingStatus {
  awaiting_host
  pending
  confirmed
  return_review
  disputed
  rejected
  cancelled
  cancelled_by_host
  completed
}

enum DisputeStatus {
  PENDING
  EXPERT_ASSIGNED
  RESOLVED
}

enum PlanType {
  basic
  standard
  premium
}

enum PolicyStatus {
  inactive
  active
  expired
  claimed
}

enum TransactionType {
  payment
  deposit_hold
  refund
  payout
}

enum TransactionStatus {
  pending
  succeeded
  authorized
  failed
  released
}

enum VerificationStatus {
  UNVERIFIED
  SUBMITTED
  APPROVED
  REJECTED
}

enum CarListingStatus {
  PENDING
  APPROVED
  REJECTED
}

model Profile {
  id                 String             @id @default(cuid())
  email              String?            @unique
  fullName           String
  phone              String?
  idNumber           String?            @unique
  country            String             @default("GE")
  passwordHash       String?
  role               UserRole           @default(USER)
  bio                String?
  isVerified              Boolean            @default(false)
  verificationStatus      VerificationStatus @default(UNVERIFIED)
  driverLicenseFront      String?
  driverLicenseBack       String?
  selfieUrl               String?
  hostVerified                     Boolean            @default(false)
  hostVerificationStatus           VerificationStatus @default(UNVERIFIED)
  idCardFront                      String?
  idCardBack                       String?
  hostSelfieUrl                    String?
  lang                             String             @default("en")
  verificationRejectionComment     String?
  hostVerificationRejectionComment String?
  rating                           Float              @default(0)
  reviewCount                      Int                @default(0)
  reviewsGiven                     Review[]           @relation("ReviewsGiven")
  reviewsReceived                  Review[]           @relation("ReviewsReceived")
  emailVerified                    Boolean            @default(false)
  emailVerificationCode            String?
  emailVerificationExpiry          DateTime?
  passwordResetCode                String?
  passwordResetExpiry              DateTime?
  penaltyBookingsRemaining         Int?
  penaltyCommissionRate            Float?
  isSuspended                      Boolean            @default(false)
  suspensionReason                 String?
  cars               Car[]
  bookings           Booking[]          @relation("GuestBookings")
  notifications      Notification[]
  coupons            Coupon[]
  createdAt          DateTime           @default(now())
  supportConversations SupportConversation[]
}

model Car {
  id                String    @id @default(cuid())
  ownerId           String
  owner             Profile   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  brand             String
  model             String
  year              Int
  plateNumber       String
  dailyPrice        Int
  location          String
  carType           String    @default("Economy")
  transmission      String    @default("Automatic")
  features          String[]
  imageUrls         String[]
  description       String?
  techPassportFront    String?
  techPassportBack     String?
  isActive             Boolean   @default(true)
  color                String    @default("")
  seats                Int       @default(5)
  doors                Int       @default(4)
  fuelType             String    @default("Petrol")
  airportTbilisiState  String    @default("none")
  airportTbilisiPrice  Int       @default(0)
  airportKutaisiState  String    @default("none")
  airportKutaisiPrice  Int       @default(0)
  airportBatumiState   String    @default("none")
  airportBatumiPrice   Int       @default(0)
  cityDeliveryEnabled  Boolean   @default(false)
  cityDeliveryCity     String    @default("")
  cityDeliveryPrice    Int       @default(0)
  returnPolicy            String           @default("same")
  minDays                 Int              @default(1)
  advanceNotice           Int              @default(2)
  steeringWheel           String           @default("left")
  estimatedValueUsd       Int?
  depositGel              Int              @default(250)
  listingStatus           CarListingStatus @default(APPROVED)
  listingRejectionComment String?
  createdAt               DateTime         @default(now())
  availability            CarAvailability[]
  bookings                Booking[]        @relation("CarBookings")
}

model Booking {
  id               String            @id @default(cuid())
  carId            String?
  car              Car?              @relation("CarBookings", fields: [carId], references: [id], onDelete: SetNull)
  carBrand         String            @default("")
  carModel         String            @default("")
  carYear          Int               @default(0)
  guestId          String
  guest            Profile           @relation("GuestBookings", fields: [guestId], references: [id], onDelete: Cascade)
  startDate        DateTime
  endDate          DateTime
  totalPrice       Int
  deliveryType     String            @default("none")
  deliveryCost     Int               @default(0)
  deliveryAddress  String?
  status           BookingStatus     @default(awaiting_host)
  hostApprovalDeadline    DateTime?
  platformFeeGel          Int              @default(0)
  cancelledAt             DateTime?
  cancellationOtpCode     String?
  cancellationOtpExpiry   DateTime?
  cancelPenaltyTier       String?
  insurancePolicy  InsurancePolicy?
  transactions     Transaction[]
  conditionReports ConditionReport[]
  availability     CarAvailability[]
  reviews          Review[]
  dispute          Dispute?
  notifications    Notification[]
  coupons          Coupon[]
  createdAt        DateTime          @default(now())
}

model CarAvailability {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@unique([carId, date])
}

model InsurancePolicy {
  id               String       @id @default(cuid())
  bookingId        String       @unique
  booking          Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  planType         PlanType
  deductibleAmount Int
  status           PolicyStatus @default(inactive)
  createdAt        DateTime     @default(now())
}

model Transaction {
  id         String            @id @default(cuid())
  bookingId  String
  booking    Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  providerId String
  amount     Int
  type       TransactionType
  status     TransactionStatus @default(pending)
  createdAt  DateTime          @default(now())
}

model ConditionReport {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  phase     String
  photoUrls String[]
  notes     String?
  createdAt DateTime @default(now())
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   Profile  @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId String
  reviewee   Profile  @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  role       String   // "guest" = guest reviewing host, "host" = host reviewing guest
  rating     Int      // 1–5
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([bookingId, reviewerId])
}

model AdminEmail {
  id          String                 @id @default(cuid())
  from        String
  to          String
  cc          String?
  bcc         String?
  subject     String
  body        String
  status      AdminEmailStatus       @default(sent)
  resendId    String?
  attachments AdminEmailAttachment[]
  createdAt   DateTime               @default(now())
}

model AdminEmailAttachment {
  id           String     @id @default(cuid())
  emailId      String
  email        AdminEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  fileType     String?
  fileSize     Int?
  cloudinaryId String?
  createdAt    DateTime   @default(now())
}

enum AdminEmailStatus {
  sent
  failed
}

model Dispute {
  id           String        @id @default(cuid())
  bookingId    String        @unique
  booking      Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  hostComment  String
  hostPhotos   String[]
  status       DisputeStatus @default(PENDING)
  damageAmount Float?
  expertFee    Float?
  expertNote   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Coupon {
  id              String   @id @default(cuid())
  userId          String
  user            Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  discountPercent Int
  expiresAt       DateTime
  used            Boolean  @default(false)
  usedAt          DateTime?
  triggeredBy     String   @default("host_cancellation")
  bookingId       String
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum SupportConversationStatus {
  open
  escalated
  closed
}

enum SupportSender {
  user
  assistant
  admin
  system
}

model SupportConversation {
  id        String                    @id @default(cuid())
  userId    String?
  user      Profile?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName String?
  guestEmail String?
  guestLang String                    @default("en")
  status    SupportConversationStatus @default(open)
  escalated Boolean                   @default(false)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  messages  SupportMessage[]
}

model SupportMessage {
  id             String              @id @default(cuid())
  conversationId String
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         SupportSender
  content        String
  createdAt      DateTime            @default(now())
}